# Copy to ".env.local" when testing against a SEPARATE Supabase project
# (create a new project at https://supabase.com/dashboard — do not reuse broken DB keys until fixed)
#
# After creating the project:
#  Project Settings → API → Project URL, anon public key, service_role key

NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...your_anon_key
SUPABASE_SERVICE_ROLE_KEY=eyJ...your_service_role_key

# Optional: site URL for redirects (Stripe, auth)
NEXT_PUBLIC_SITE_URL=http://localhost:3000
